---
import { useTranslations, resolveLabel } from '../i18n/index';
import Configurator from './configurator/Configurator.svelte';
import rawCarsData from '../content/cars.json';
import rawMaterialsData from '../content/materials.json';
import pricingData from '../content/pricing.json';
import type { RawCarBrand, CarBrand, RawMatClass, MatClass, Locale } from '../components/configurator/types';

const { locale = 'ro' } = Astro.props;
const t = useTranslations(locale);
const loc = locale as Locale;

// Resolve locale in cars data
const cars: CarBrand[] = (rawCarsData.brands as RawCarBrand[]).map((brand) => ({
  name: brand.name,
  models: brand.models.map((model) => ({
    name: model.name,
    yearRange: model.yearRange,
    options: model.options.map((opt) => ({
      label: resolveLabel(opt.label, loc),
      meters: opt.meters,
      suboptions: opt.suboptions.map((sub) => ({
        id: sub.id,
        label: resolveLabel(sub.label, loc),
        extraMeters: sub.extraMeters,
      })),
    })),
  })),
}));

// Resolve locale in materials data
const materials: { classes: MatClass[] } = {
  classes: (rawMaterialsData.classes as RawMatClass[]).map((cls) => ({
    id: cls.id,
    label: resolveLabel(cls.label, loc),
    items: cls.items.map((item) => ({
      id: item.id,
      label: typeof item.label === 'string' ? item.label : resolveLabel(item.label as { ro: string; ru: string; en: string }, loc),
      pricePerMeter: item.pricePerMeter,
      image: item.image,
      demoImage: item.demoImage,
    })),
  })),
};

const heroImageSrc = `${import.meta.env.BASE_URL}/hero-mats.png`;

const labels = {
  step1: t('configurator.step1'),
  step2: t('configurator.step2'),
  step3: t('configurator.step3'),
  brand: t('configurator.make'),
  model: t('configurator.model'),
  option: t('configurator.option'),
  selectBrand: t('configurator.selectMake'),
  selectModel: t('configurator.selectModel'),
  selectOption: t('configurator.selectOption'),
  matClass: t('configurator.matClass'),
  matItem: t('configurator.matItem'),
  protectiveWith: t('configurator.protectiveWith'),
  protectiveWithout: t('configurator.protectiveWithout'),
  protectiveOnly: t('configurator.protectiveOnly'),
  totalPrice: t('configurator.totalPrice'),
  currency: t('configurator.currency'),
  formTitle: t('form.title'),
  formName: t('form.name'),
  formPhone: t('form.phone'),
  formEmail: t('form.email'),
  formSubmit: t('form.submit'),
  formSuccess: t('form.success'),
  formError: t('form.error'),
  formConfigSummary: t('form.configSummary'),
};
---

<section id="configurator" class="max-w-7xl mx-auto px-4 py-6 sm:py-10">

  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1">{t('hero.title')}</h1>
  <p class="text-sm sm:text-base text-gray-500 mb-5">{t('hero.subtitle')}</p>

  <Configurator
    client:only="svelte"
    cars={JSON.stringify({ brands: cars })}
    materials={JSON.stringify(materials)}
    pricing={JSON.stringify(pricingData)}
    {heroImageSrc}
    {locale}
    {labels}
  />

</section>
