---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations } from '../i18n/index';

const { locale = 'ro' } = Astro.props;
const t = useTranslations(locale);

const locales = [
  { code: 'ro', label: 'RO' },
  { code: 'ru', label: 'RU' },
  { code: 'en', label: 'EN' },
];
---

<header class="border-b border-gray-200 bg-white sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between gap-4">
    <a href={getRelativeLocaleUrl(locale, '/')} class="shrink-0">
      <img src={`${import.meta.env.BASE_URL}/logo.jpg`} alt="Hanter.md" class="h-9 w-auto rounded" />
    </a>

    <div class="flex items-center gap-3 sm:gap-6 min-w-0">
      <a href="#configurator" class="text-sm text-gray-600 hover:text-gray-900 transition-colors hidden sm:block">
        {t('nav.configurator')}
      </a>
      <a href="#contact" class="text-sm text-gray-600 hover:text-gray-900 transition-colors hidden sm:block">
        {t('nav.contact')}
      </a>

      <div class="flex items-center gap-0.5 shrink-0">
        {locales.map(({ code, label }) => (
          <a
            href={getRelativeLocaleUrl(code, '/')}
            class={`px-2 py-1 text-xs font-medium rounded transition-colors ${
              locale === code
                ? 'bg-gray-900 text-white'
                : 'text-gray-500 hover:text-gray-900'
            }`}
          >
            {label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>
